# Required
PI_GH_PR_REPO=owner/repo

# Delivery behavior
PI_GH_PR_MODE=notify-only
# Optional event type allowlist before session-local overrides kick in.
# Examples: all | none | merged,closed,ready_for_review
PI_GH_PR_EVENT_ACTIONS=all

# Optional message fields filter — which PR fields appear in the event message.
# Examples: all | none | pr,title,author,url
PI_GH_PR_MESSAGE_FIELDS=all

# Optional custom instruction appended to PR event messages in auto-turn mode.
# When set, the instruction is separated from PR fields by "---".
# PI_GH_PR_INSTRUCTION=Please review this PR and summarize key changes.

PI_GH_PR_POLL_INTERVAL_MS=10000
PI_GH_PR_FETCH_LIMIT=100
PI_GH_PR_COMMAND_TIMEOUT_MS=20000

# Optional gh binary override
# PI_GH_PR_GH_BIN=/opt/homebrew/bin/gh

# Optional explicit env file path if you don't want to use .env.local/.env
# PI_GH_PR_ENV_FILE=/absolute/path/to/github-pr.env
